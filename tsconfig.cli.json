{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": "./src",
    "paths": {
      "@shared/*": ["shared/*"],
      "@lib-public/*": ["lib-public/*"]
    }
  },
  "include": [
    "src/cli/**/*",
    "src/lib-public/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/app-public/**/*"
  ]
}
